# No production-ready claim.

bind_address = "${bind_address}"
port = ${port}
data_dir = "${data_dir}"
log_dir = "${log_dir}"

%{ if postgres_enabled ~}
store = "postgres"
database_url = "${store_dsn}"
%{ else ~}
store = "sqlite"
database_url = "${store_dsn}"
%{ endif ~}
