# ferrumgate.toml
# Generated by Terraform for single-node deployment.
# No production-ready claim.

[server]
bind_addr = "${bind_address}:${port}"
store_dsn = "${store_dsn}"
auth_mode = "bearer"
bearer_token = ""  # Set via FERRUMD_BEARER_TOKEN env var
allow_insecure_nonlocal_bind = false
log_filter = "info"

# data_dir and log_dir are not FerrumGate config keys; manage them via service unit and environment.
