# ferrumd.env.example
# Environment file for ferrumd.service bearer token.
# Single-node SQLite only. No PostgreSQL. No production-ready claim.
#
# DO NOT commit real tokens to version control.
# Generate a secure token with: openssl rand -hex 32
#
# Usage:
#   1. Copy to /etc/ferrumgate/ferrumd.env
#   2. Replace REPLACE_WITH_GENERATED_TOKEN with the output of:
#      openssl rand -hex 32
#   3. Set permissions: chmod 600 /etc/ferrumgate/ferrumd.env
#   4. Reference from ferrumd.service via EnvironmentFile=-/etc/ferrumgate/ferrumd.env

FERRUMD_BEARER_TOKEN=fg_live_REPLACE_WITH_GENERATED_TOKEN

# ── MFA Environment Variables ──
# Uncomment and configure to enable TOTP credential storage.
# FERRUMD_MFA_SECRET_KEY must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
#
# FERRUMD_MFA_SECRET_KEY=REPLACE_WITH_GENERATED_KEY
# FERRUMD_MFA_TOTP_ISSUER=FerrumGate
# FERRUMD_APPROVAL_MFA_REQUIRED=false
# FERRUMD_MFA_LOCKOUT_MAX_ATTEMPTS=5
# FERRUMD_MFA_LOCKOUT_DURATION_SECS=900

# ── OIDC Environment Variables (Phase 4.4) ──
# Uncomment and configure when auth_mode = "oidc".
# These override values from the TOML config file.
#
# FERRUMD_OIDC_ISSUER=https://your-issuer.example.com
# FERRUMD_OIDC_AUDIENCES=ferrumgate
# FERRUMD_OIDC_JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json
# FERRUMD_OIDC_JWKS_CACHE_TTL_SECS=300
# FERRUMD_OIDC_ACTOR_ID_CLAIM=sub
# FERRUMD_OIDC_ROLE_SOURCE_CLAIM=groups
# FERRUMD_OIDC_REQUIRE_EMAIL_VERIFIED=true
# FERRUMD_OIDC_ALLOWED_ALGORITHMS=RS256,ES256,EdDSA
# FERRUMD_OIDC_ROLE_MAPPINGS=fg-admins=admin,fg-operators=operator
