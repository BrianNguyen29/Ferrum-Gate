# ferrumd.env.example
# Environment file for ferrumd.service bearer token.
# Single-node SQLite only. No PostgreSQL. No production-ready claim.
#
# DO NOT commit real tokens to version control.
# Generate a secure token with: openssl rand -hex 32
#
# Usage:
#   1. Copy to /etc/ferrumgate/ferrumd.env
#   2. Replace REPLACE_WITH_GENERATED_TOKEN with the output of:
#      openssl rand -hex 32
#   3. Set permissions: chmod 600 /etc/ferrumgate/ferrumd.env
#   4. Reference from ferrumd.service via EnvironmentFile=-/etc/ferrumgate/ferrumd.env

FERRUMD_BEARER_TOKEN=fg_live_REPLACE_WITH_GENERATED_TOKEN
